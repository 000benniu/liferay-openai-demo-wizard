{
  "kind": "StatefulSet",
  "id": "liferayOpenAIWizard",
  "memory": 2048,
  "cpu": 1,
  "scale": 1,
  "loadBalancer": {
    "targetPort": 4020,
    "cdn": false,
    "customDomains": []
  },
  "readinessProbe": {
    "httpGet": {
      "path": "/",
      "port": 4020
    },
    "initialDelaySeconds": 30,
    "periodSeconds": 10,
    "timeoutSeconds": 5,
    "successThreshold": 1,
    "failureThreshold": 3
  },
  "env": {
    "NODE_ENV": "production",
    "PORT": "4020"
  },
  "environments": {
    "infra": {
      "deploy": false
    }
  }
} 