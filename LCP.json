{
    "kind": "Deployment",
    "id": "liferayOpenAIWizard",
    "memory": 248,
    "cpu": 0.2,
    "scale": 1,
    "loadBalancer": {
      "targetPort": 3000
    },
    "readinessProbe": {
      "httpGet": {
        "path": "/",
        "port": 3000
      }
    },
    "livenessProbe": {
      "httpGet": {
        "path": "/",
        "port": 3000
      }
    },
    "env": {
      "NODE_ENV": "production",
      "PORT": "3000"
    },
    "environments": {
      "infra": {
        "deploy": false
      }
    }
  } 