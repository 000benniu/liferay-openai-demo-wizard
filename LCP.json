{
  "kind": "Deployment",
  "id": "liferayOpenAIWizard",
  "memory": 2048,
  "cpu": 1,
  "scale": 1,
  "loadBalancer": {
    "targetPort": 4020
  },
  "readinessProbe": {
    "httpGet": {
      "path": "/",
      "port": 4020
    }
  },
  "livenessProbe": {
    "httpGet": {
      "path": "/",
      "port": 4020
    }
  },
  "env": {
    "NODE_ENV": "production",
    "PORT": "4020"
  },
  "environments": {
    "infra": {
      "deploy": false
    }
  }
} 